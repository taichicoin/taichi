<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TAICHI Airdrop Check</title>
<style>
  *{box-sizing:border-box;font-family:system-ui}
  body{max-width:500px;margin:40px auto;padding:0 20px;background:#0a0a12;color:#fff}
  .card{background:#161625;padding:24px;border-radius:16px;margin-bottom:20px}
  button{padding:12px 24px;background:#0089ff;color:#fff;border:none;border-radius:10px;cursor:pointer;font-weight:bold;margin:4px}
  .status{padding:12px;border-radius:8px;margin:10px 0}
  .ok{background:#1b3b2b;color:#9eff9e}
  .no{background:#3b1b1b;color:#ff9e9e}
  input{width:100%;padding:12px;margin:8px 0;background:#10101e;border:1px solid #333;border-radius:10px;color:#fff}
</style>
</head>

<body>
<div class="card">
  <h2>TAICHI Airdrop Check</h2>
  <button id="connect">Connect Wallet</button>
  <div id="address"></div>
</div>

<div class="card">
  <h3>Check Eligibility</h3>
  <button id="check">Check Now</button>
  <div id="result"></div>
</div>

<div class="card" id="form" style="display:none">
  <h3>Register</h3>
  <input id="twitter" placeholder="Twitter / X">
  <input id="tg" placeholder="Telegram">
  <input id="email" placeholder="Email">
  <button id="submit">Submit</button>
</div>

<script>
const API_KEY = "BVI7MUXSXWAC6NXRIXPD4GQQVRT3CH7J86";
const CUTOFF_TIME = 1770624000; // 2026-02-10 00:00 UTC
let addr = "";

// 连接钱包（原生 EIP-1193，兼容所有主流钱包）
document.getElementById("connect").onclick = async () => {
  if(!window.ethereum) {
    alert("请在钱包 DApp 浏览器中打开此页面，或安装 MetaMask/OKX 钱包扩展");
    return;
  }
  try {
    // 切换到 BNB Chain（可选，避免连错链）
    await window.ethereum.request({
      method: "wallet_addEthereumChain",
      params: [{
        chainId: "0x38", // BSC 链 ID
        chainName: "BNB Smart Chain",
        nativeCurrency: { name: "BNB", symbol: "BNB", decimals: 18 },
        rpcUrls: ["https://bsc-dataseed.binance.org/"],
        blockExplorerUrls: ["https://bscscan.com/"]
      }]
    });
    
    const accounts = await window.ethereum.request({ method: "eth_requestAccounts" });
    addr = accounts[0];
    document.getElementById("address").innerText = "地址：" + addr;
  } catch(e) {
    alert("连接取消或失败：" + e.message);
    console.error(e);
  }
};

// 检查 Gas + 阶梯空投
document.getElementById("check").onclick = async () => {
  if(!addr) return alert("先连接钱包");
  const r = document.getElementById("result");
  r.innerHTML = "Checking gas...";

  try {
    const res = await fetch(
      `https://api.bscscan.com/api`
      + `?module=account&action=txlist`
      + `&address=${addr}`
      + `&endtimestamp=${CUTOFF_TIME}`
      + `&apikey=${API_KEY}`
    );
    const data = await res.json();

    let gasTotal = 0;
    if (data.result) {
      for (const tx of data.result) {
        if (tx.from.toLowerCase() === addr.toLowerCase() && tx.txreceipt_status == "1") {
          const gas = (Number(tx.gasUsed) * Number(tx.gasPrice)) / 1e18;
          gasTotal += gas;
        }
      }
    }

    // 阶梯判定
    let airdrop = 0;
    let text = "";

    if (gasTotal >= 0.01 && gasTotal < 0.02) {
      airdrop = 500;
    } else if (gasTotal >= 0.02 && gasTotal < 0.03) {
      airdrop = 800;
    } else if (gasTotal >= 0.03 && gasTotal < 0.04) {
      airdrop = 1000;
    } else if (gasTotal >= 0.04 && gasTotal < 0.05) {
      airdrop = 1500;
    } else if (gasTotal >= 0.05 && gasTotal < 0.1) {
      airdrop = 1600;
    } else if (gasTotal >= 0.1) {
      airdrop = 2000;
    }

    if (airdrop > 0) {
      text = `<div class="ok">✅ 符合资格<br>Gas 消耗：${gasTotal.toFixed(4)} BNB<br>空投数量：${airdrop} TAICHI</div>`;
      document.getElementById("form").style.display = "block";
    } else {
      text = `<div class="no">❌ 不符合资格<br>Gas 消耗：${gasTotal.toFixed(4)} BNB</div>`;
      document.getElementById("form").style.display = "none";
    }

    r.innerHTML = text;
  } catch(e) {
    r.innerHTML = "查询失败，请重试";
    console.error(e);
  }
};

// 提交登记
document.getElementById("submit").onclick = () => {
  const twitter = document.getElementById("twitter").value;
  const tg = document.getElementById("tg").value;
  const email = document.getElementById("email").value;
  alert(
    "登记成功！\n\n" +
    "地址：" + addr + "\n" +
    "Twitter：" + twitter + "\n" +
    "Telegram：" + tg + "\n" +
    "邮箱：" + email
  );
};
</script>
</body>
</html>
